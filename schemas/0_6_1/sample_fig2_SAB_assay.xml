                        <interpretation-software-version>4.1</interpretation-software-version>
                        <raw-MFI-divider>0.56</raw-MFI-divider>
                    </assay-kit>

                    <!-- Assay-level interpretation -->
                    <assay-interpretation>
                        <interpretation-context>Kidney Transplantation Workup</interpretation-context>
                        <interpretation-context-comment>This pre-tranplant screen was performed 2 weeks before transplant to check if they had developed antibodies due to a transfusion.</interpretation-context-comment>
                        <specificities>
