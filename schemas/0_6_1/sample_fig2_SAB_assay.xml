                            <specificities-string>A1+A2+B7+B*51:02</specificities-string>
                            <!-- <negative-specificities>A2</negative-specificities> -->
                            <!-- <questionable-specificities>DR4</questionable-specificities> -->
                        </specificities>
                        <reject-assay>false</reject-assay>

                        <!-- <reject-reason>Contamination</reject-reason> -->
                        <!-- <failure-code>3</failure-code> -->

                    </assay-interpretation>
                    
                </assay>
